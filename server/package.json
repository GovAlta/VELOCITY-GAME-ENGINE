{
  "name": "goa-services-portal-server",
  "version": "1.0.0",
  "description": "Velo — Express API backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:rollback": "tsx src/scripts/rollback.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "set-role": "tsx src/scripts/set-role.ts",
    "generate-keys": "tsx src/scripts/generate-keys.ts",
    "generate-secrets": "tsx src/scripts/generate-secrets.ts"
  },
  "dependencies": {
    "@types/yauzl": "^2.10.3",
    "ajv": "^8.18.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openid-client": "^5.7.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "winston": "^3.19.0",
    "yauzl": "^3.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/jszip": "^3.4.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
