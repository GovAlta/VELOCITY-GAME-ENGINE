# =============================================================================
# Velo Server — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# Then generate secrets: npm run generate-secrets
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/velo

# ── Client Serving ───────────────────────────────────────────────────────────
# true = Express serves app/client/dist/ as static files (auto-enabled in production)
# false = use Vite dev server separately (npm run dev:all)
SERVE_CLIENT=false

# ── URLs ─────────────────────────────────────────────────────────────────────
# CORS_ORIGIN: allowed origins for CORS and OAuth redirects
#   Dev:  http://localhost:5173
#   Prod: https://your-app.onrender.com
CORS_ORIGIN=http://localhost:5173

# API_BASE_URL: public-facing server URL for OAuth callback URLs
#   Dev:  http://localhost:3001
#   Prod: https://your-app.onrender.com
API_BASE_URL=http://localhost:3001

# ── JWT (RSA-2048 Key Pairs for RS256 Signing) ──────────────────────────────
# How keys are loaded (see utils/token.ts):
#   1. Checks server/keys/*.pem files on disk (development)
#   2. Falls back to these env vars (production — Azure Key Vault)
#   3. If neither exists → server crashes at startup
#
# Dev:  Run "npm run generate-secrets" to create PEM files in server/keys/
# Prod: Set all 4 vars below with PEM contents (newlines escaped as \n)
#       Generate with: npm run generate-keys -- --env
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_REFRESH_PRIVATE_KEY=
JWT_REFRESH_PUBLIC_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Symmetric Secrets ────────────────────────────────────────────────────────
# Generate with: npm run generate-secrets
# ENCRYPTION_KEY: AES-256-CBC key for encrypting sensitive data (min 16 chars, recommended 64 hex)
ENCRYPTION_KEY=
# CSRF_SECRET: HMAC-SHA256 key for CSRF double-submit tokens (min 32 chars, recommended 96 hex)
CSRF_SECRET=

# ── OAuth SSO: Google ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth SSO: Microsoft ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── AI / LLM Providers ──────────────────────────────────────────────────────
# At least one provider key is needed for audits and AI file processing
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Legacy AI config (optional, used by older AI features)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1024
OPENAI_API_KEY=

# ── GitHub Integration ───────────────────────────────────────────────────────
# System-level GitHub PAT for repository access (optional — users can add their own)
GITHUB_PAT=

# ── SharePoint Integration (Microsoft Graph API) ────────────────────────────
# Azure AD app registration with Sites.ReadWrite.All application permission
SHAREPOINT_APPLICATION_CLIENT_ID=
SHAREPOINT_APPLICATION_CLIENT_SECRET=
SHAREPOINT_APPLICATION_TENANT_ID=
SHAREPOINT_SITE_URL=

# ── Database Pool ────────────────────────────────────────────────────────────
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_API_MAX=20000
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=3000
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AI_MAX=6000
RATE_LIMIT_AI_WINDOW_MS=3600000

# ── Request Body Size Limits ─────────────────────────────────────────────────
BODY_LIMIT_JSON=1mb
BODY_LIMIT_URLENCODED=1mb
