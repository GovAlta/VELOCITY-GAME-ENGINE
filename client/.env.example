# =============================================================================
# Velo Client Environment Variables (Vite)
# Only VITE_* variables are exposed to the client bundle.
# Copy to .env for local overrides: cp .env.example .env
# =============================================================================

# API base path. In dev, Vite proxies /api to the backend (see vite.config.ts).
# In production, the server serves both the client and API from the same origin,
# so /api resolves naturally — no change needed.
VITE_API_BASE_URL=/api

# App title (used in document.title and header)
VITE_APP_TITLE=Velo
